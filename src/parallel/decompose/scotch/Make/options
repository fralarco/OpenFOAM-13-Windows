# Note including of mplib compilation rules.
# This is purely to avoid scotch.h including mpicxx.h, which causes problems.

-include $(GENERAL_RULES)/mplibType

EXE_INC = \
    $(PFLAGS) $(PINC) \
    -I$(SCOTCH_ARCH_PATH)/include \
    -I$(or $(SCOTCH_INCLUDE_DIR),/usr/include/scotch) \
    -I../decompositionMethods/lnInclude

LIB_LIBS = \
    -L$(SCOTCH_ARCH_PATH)/lib \
    $(if $(SCOTCH_LIB_DIR),-L$(SCOTCH_LIB_DIR)) \
    -L$(FOAM_EXT_LIBBIN) \
    -lscotch \
    -lscotcherrexit \
    $(if $(filter mingw_w64,$(WM_ARCH)),-lpthread,-lrt)

# PE/COFF has no lazy symbol resolution: the decompositionMethod base class
# (and libOpenFOAM) must be linked explicitly. ELF resolves these at load time.
ifeq ($(WM_ARCH),mingw_w64)
LIB_LIBS += -ldecompositionMethods
endif
