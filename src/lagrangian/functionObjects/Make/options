EXE_INC = \
    -I$(LIB_SRC)/finiteVolume/lnInclude \
    -I$(LIB_SRC)/physicalProperties/lnInclude \
    -I$(LIB_SRC)/meshTools/lnInclude \
    -I$(LIB_SRC)/tracking/lnInclude \
    -I$(LIB_SRC)/lagrangian/basic/lnInclude \
    -I$(LIB_SRC)/lagrangian/parcel/lnInclude \
    -I$(LIB_SRC)/lagrangian/DSMC/lnInclude \
    -I$(LIB_SRC)/functionObjects/utilities/lnInclude

LIB_LIBS = \
    -lfiniteVolume \
    -lphysicalProperties \
    -lmeshTools \
    -llagrangian \
    -llagrangianParcel \
    -lutilityFunctionObjects

ifeq ($(WM_ARCH),mingw_w64)
    # PE/COFF requires explicit link closure for directly
    # referenced symbols; ELF resolves them at load time
    LIB_LIBS += -ltracking
endif
