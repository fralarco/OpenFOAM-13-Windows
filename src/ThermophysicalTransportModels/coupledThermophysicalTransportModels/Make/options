EXE_INC = \
    -I$(LIB_SRC)/ThermophysicalTransportModels/thermophysicalTransportModel/lnInclude \
    -I$(LIB_SRC)/finiteVolume/lnInclude \
    -I$(LIB_SRC)/meshTools/lnInclude \

LIB_LIBS = \
    -lthermophysicalTransportModel \
    -lfiniteVolume \
    -lmeshTools

ifeq ($(WM_ARCH),mingw_w64)
    # PE/COFF requires explicit link closure for directly
    # referenced symbols; ELF resolves them at load time
    LIB_LIBS += -lfluidThermophysicalTransportModel -lthermophysicalTransportModel
endif
