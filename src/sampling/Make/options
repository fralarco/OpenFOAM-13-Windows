EXE_INC = \
    -I$(LIB_SRC)/finiteVolume/lnInclude \
    -I$(LIB_SRC)/meshTools/lnInclude \
    -I$(LIB_SRC)/surfMesh/lnInclude \
    -I$(LIB_SRC)/fileFormats/lnInclude \
    -I$(LIB_SRC)/triSurface/lnInclude \
    -I$(LIB_SRC)/tracking/lnInclude \
    -I$(LIB_SRC)/lagrangian/basic/lnInclude

LIB_LIBS = \
    -lfiniteVolume \
    -lmeshTools \
    -lsurfMesh \
    -lfileFormats \
    -ltriSurface \
    -llagrangian

ifeq ($(WM_ARCH),mingw_w64)
    # PE needs the full link closure: tracking symbols are referenced
    # directly (particle::hitFace instantiations) but reach ELF builds
    # transitively through liblagrangian
    LIB_LIBS += -ltracking
endif
