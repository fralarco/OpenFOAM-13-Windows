FoamFile
{
    format      ascii;
    class       dictionary;
    object      fluidThermo;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

type
(
    hePsiThermo
    heRhoThermo
);

typeRenamed
(
    hePsiThermo psiThermo
    heRhoThermo rhoFluidThermo
);

energy
(
    sensibleEnthalpy
    absoluteEnthalpy
    sensibleInternalEnergy
    absoluteInternalEnergy
);

mixture
(
    pureMixture
);

transport
(
    const
    icoTabulated
    logPolynomial
    polynomial
    sutherland
    tabulated
    WLF
    Andrade
);

thermo
(
    eConst
    eIcoTabulated
    ePolynomial
    ePower
    eTabulated
    hConst
    hIcoTabulated
    hPolynomial
    hPower
    hTabulated
    janaf
);

equationOfState
(
    adiabaticPerfectFluid
    Boussinesq
    icoPolynomial
    icoTabulated
    incompressiblePerfectGas
    linear
    PengRobinsonGas
    perfectFluid
    perfectGas
    rhoConst
    rhoTabulated
    rPolynomial
);

specie
(
    specie
);

codeOptions
#{
EXE_INC = \
    -I$(LIB_SRC)/physicalProperties/lnInclude \
    -I$(LIB_SRC)/thermophysicalModels/specie/lnInclude \
    -I$(LIB_SRC)/thermophysicalModels/thermophysicalProperties/lnInclude \
    -I$(LIB_SRC)/thermophysicalModels/basic/lnInclude \
    -I$(LIB_SRC)/finiteVolume/lnInclude
#};

// Windows (PE/COFF) resolves a DLL's referenced symbols against import
// libraries at link time; ELF resolves them at dlopen from the loaded process.
// Give the generated library the link closure matching the EXE_INC above.
// Guarded to mingw so Linux keeps its empty LIB_LIBS and unchanged behaviour.
codeLibs
#{
ifeq ($(WM_ARCH),mingw_w64)
LIB_LIBS = \
    -lfiniteVolume \
    -lfluidThermophysicalModels \
    -lthermophysicalProperties \
    -lspecie \
    -lphysicalProperties \
    -lOpenFOAM
endif
#};


