#------------------------------------------------------------------------------
# The Makefile uses a POSIX shell
#------------------------------------------------------------------------------

SHELL           = /bin/sh


#------------------------------------------------------------------------------
# Unset suffices list (suffix rules are not used)
#------------------------------------------------------------------------------

.SUFFIXES:


#------------------------------------------------------------------------------
# Set the directory containing the wmake scripts
#------------------------------------------------------------------------------

WM_SCRIPTS      = $(WM_DIR)/scripts


#------------------------------------------------------------------------------
# Declare default paths
#------------------------------------------------------------------------------

LIB_SRC         = $(WM_PROJECT_DIR)/src
LIB_PLATFORMS   = $(WM_PROJECT_DIR)/platforms/$(WM_OPTIONS)/lib
OBJECTS_DIR     = $(MAKE_DIR)/$(WM_OPTIONS)
OPTIONS         = $(MAKE_DIR)/options
FILES           = $(MAKE_DIR)/files

SYS_INC         =
SYS_LIBS        =

PROJECT_INC     = -I$(LIB_SRC)/$(WM_PROJECT)/lnInclude \
		     -I$(LIB_SRC)/OSspecific/$(WM_OSTYPE)/lnInclude

PROJECT_LIBS    = -l$(WM_PROJECT)

EXE_INC         =
EXE_LIBS        =

LIB_LIBS        =

# For backward compatibility set FILES to $(OBJECTS_DIR)/files if it has been
# created from $(MAKE_DIR)/files that does not contain the SOURCE entry
ifneq ("$(wildcard $(OBJECTS_DIR)/files)","")
    FILES = $(OBJECTS_DIR)/files
endif


#------------------------------------------------------------------------------
# Declare default name of libraries and executables
#------------------------------------------------------------------------------

# Library
LIB             = libNULL

# Shared library extension
SO              = so

# Project executable
EXE             = $(WM_PROJECT).out

# Standalone executable
SEXE            = a.out


#------------------------------------------------------------------------------
# Set compilation and dependency building rules
#------------------------------------------------------------------------------

GENERAL_RULES = $(WM_DIR)/rules/General
include $(GENERAL_RULES)/general


#------------------------------------------------------------------------------
# Include the options file which might contain specific rules, suffixes etc.
#------------------------------------------------------------------------------

include $(OPTIONS)
include $(GENERAL_RULES)/transform


#------------------------------------------------------------------------------
# Include the files file containing the list of source files to compile
#------------------------------------------------------------------------------

include $(FILES)

ifeq ($(WM_ARCH),mingw_w64)
#------------------------------------------------------------------------------
# Windows: short hashed object/dependency directories.
# The upstream scheme mirrors the full source tree under platforms/, pushing
# object paths past MAX_PATH (260) on a normal checkout (measured 290). Here
# each source's object/dep goes to
#     platforms/<WM_OPTIONS>/obj/<H>/<basename>.o
# where H = sha1(abs source dir)[:16] — stable, and collision-free because
# basenames within one directory are already unique. This removes the need
# for subst O:/junctions/LongPathsEnabled. A make pattern rule cannot express
# the directory remap (the object stem no longer carries the source subdir),
# so explicit per-source compile+dep rules are generated below.
#------------------------------------------------------------------------------
WIN_OBJ_ROOT := $(WM_PROJECT_DIR)/platforms/$(WM_OPTIONS)/obj
_winSrcDirs := $(sort $(dir $(SOURCE)))
$(foreach d,$(_winSrcDirs),\
  $(eval _winH_$(d) := $(shell printf '%s' '$(abspath $(d))' | sha1sum | cut -c1-16)))
winObjDir = $(WIN_OBJ_ROOT)/$(_winH_$(dir $(1)))

OBJECTS := $(foreach s,$(SOURCE),$(call winObjDir,$s)/$(notdir $(basename $s)).o)
DEPENDENCIES := $(foreach s,$(SOURCE),$(call winObjDir,$s)/$(notdir $s).dep)

define WIN_SRC_RULES
$(call winObjDir,$1)/$(notdir $(basename $1)).o: $1 $(call winObjDir,$1)/$(notdir $1).dep
	@$(WM_SCRIPTS)/makeTargetDir $$@
	$(call QUIET_MESSAGE,$(subst .,,$(suffix $1))too,$(notdir $1))
	$E $$($(subst .,,$(suffix $1))too)
$(call winObjDir,$1)/$(notdir $1).dep: $1
	@$(WM_SCRIPTS)/makeTargetDir $$@
	$(call QUIET_MESSAGE,wmkdep,$(notdir $1))
	@$(WMAKE_BIN)/wmkdep \
		-R '$(WIN_OBJ_ROOT)/' '$$$$(WIN_OBJ_ROOT)/' \
		-R '$(WM_PROJECT_DIR)/' '$$$$(WM_PROJECT_DIR)/' \
		$(LIB_HEADER_DIRS) $$< $$@
endef
$(foreach s,$(SOURCE),$(eval $(call WIN_SRC_RULES,$s)))
else
DEPENDENCIES=$(SOURCE:%=$(OBJECTS_DIR)/%.dep)
BASENAMES=$(basename $(SOURCE))
OBJECTS=$(BASENAMES:%=$(OBJECTS_DIR)/%.o)
endif


#------------------------------------------------------------------------------
# Set header file include paths
#------------------------------------------------------------------------------

ifeq ($(WM_ARCH),mingw_w64)
# On a case-insensitive NTFS build directory, OpenFOAM headers whose
# basenames collide case-insensitively with C/C++ system headers
# (notably string.H <-> <string.h>) would shadow the system header, because
# -I directories are searched for BOTH "" and <> includes. Use -iquote for
# OpenFOAM's own directories: they are then searched for "" includes only,
# leaving <string.h>/<cstring>/<fstream> to resolve to the real system
# headers. GINC/SYS_INC (ThirdParty/system) keep -I.
LIB_HEADER_DIRS = \
        $(patsubst -I%,-iquote %,$(EXE_INC)) \
        -iquote lnInclude \
        -iquote . \
        $(patsubst -I%,-iquote %,$(PROJECT_INC)) \
        $(GINC) \
        $(SYS_INC)
else
LIB_HEADER_DIRS = \
        $(EXE_INC) \
        -IlnInclude \
        -I. \
        $(PROJECT_INC) \
        $(GINC) \
        $(SYS_INC)
endif


#------------------------------------------------------------------------------
# Define link statements for executables
#------------------------------------------------------------------------------

.PHONY: all
all: $(EXE)
	@:

.PHONY: silent
silent:
	@:

$(EXE): $(OBJECTS)
	@$(WM_SCRIPTS)/makeTargetDir $(EXE)
	$(call QUIET_MESSAGE,ld,$(EXE))
	$E $(LINKEXE) $(OBJECTS) -L$(LIB_PLATFORMS) \
	    $(EXE_LIBS) $(PROJECT_LIBS) $(SYS_LIBS) \
	    $(LINK_LIBS) $(GLIBS) -o $(EXE)

.PHONY: exe
exe: $(SEXE) | silent

$(SEXE): $(OBJECTS)
	@$(WM_SCRIPTS)/makeTargetDir $(SEXE)
	$(call QUIET_MESSAGE,ld,$(SEXE))
	$E $(LINKEXE) $(OBJECTS) $(EXE_LIBS) \
	    $(SYS_LIBS) $(LINK_LIBS) $(GLIBS) -o $(SEXE)


#------------------------------------------------------------------------------
# Define link statements for libraries
#------------------------------------------------------------------------------

.PHONY: objects
objects: $(OBJECTS) | silent

.PHONY: libso
libso: $(LIB).$(SO) | silent

# PE images cannot contain unresolved symbols, so on Windows every
# OpenFOAM library AND executable must link against libOpenFOAM and
# libPstream (ELF resolves these lazily at load time)
ifeq ($(WM_ARCH),mingw_w64)
    PROJECT_LIBS += -L$(LIB_PLATFORMS)/$(FOAM_MPI) -lPstream
ifneq ($(notdir $(LIB)),libOpenFOAM)
    MINGW_PROJECT_LIBS = $(PROJECT_LIBS)
endif
endif

$(LIB).$(SO): $(OBJECTS)
	@$(WM_SCRIPTS)/makeTargetDir $(LIB)
	$(call QUIET_MESSAGE,ld,$(LIB).$(SO))
ifeq ($(WM_ARCH),mingw_w64)
# Windows command lines cannot hold the full object list: pass the
# objects through a GCC response file, converting the MSYS-style paths
# to Windows form (no automatic conversion happens inside @files).
# The list is reversed (tac): the MinGW CRT runs .ctors in reverse link
# order while ELF init_array runs forward, so reversing restores the
# upstream static-initialisation order (word::null before its users)
	$(file >$(LIB).objs)$(foreach O,$(OBJECTS),$(file >>$(LIB).objs,$O))
	$E tac $(LIB).objs | cygpath -m -f - > $(LIB).rsp
	$E $(LINKLIBSO) @$(LIB).rsp -L$(LIB_PLATFORMS) \
	    $(LIB_LIBS) $(GLIB_LIBS) $(MINGW_PROJECT_LIBS) -o $(LIB).$(SO)
else
	$E $(LINKLIBSO) $(OBJECTS) -L$(LIB_PLATFORMS) \
	    $(LIB_LIBS) $(GLIB_LIBS) -o $(LIB).$(SO)
endif

.PHONY: lib
lib: $(LIB).a | silent

$(LIB).a: $(OBJECTS)
	@$(WM_SCRIPTS)/makeTargetDir $(LIB)
	@rm -f $(LIB).a
	$(call QUIET_MESSAGE,ar,$(LIB))
	$E $(AR) $(ARFLAGS) $(LIB).a $(OBJECTS)
	$(call QUIET_MESSAGE,ranlib,$(notdir $(LIB)))
	$E $(RANLIB) $(LIB).a

.PHONY: libo
libo: $(LIB).o | silent

$(LIB).o: $(OBJECTS)
	@$(WM_SCRIPTS)/makeTargetDir $(LIB)
	@rm -f $(LIB).o
	$(call QUIET_MESSAGE,ld,$(LIB).o)
	$E $(LD) -r -o $(LIB).o $(OBJECTS)


#------------------------------------------------------------------------------
# Set rule to create the include directory for libraries
#------------------------------------------------------------------------------

lnInclude: $(MAKE_DIR)/files $(OPTIONS)
	@rm -rf lnInclude ; wmakeLnInclude .


#------------------------------------------------------------------------------
# Declare all object files depend on $(OPTIONS)
#------------------------------------------------------------------------------

$(OBJECTS): $(OPTIONS)
ifneq ($(WM_ARCH),mingw_w64)
$(foreach S,$(SOURCE),$(eval $(OBJECTS_DIR)/$(basename $S).o : $(OBJECTS_DIR)/$S.dep))
endif


#------------------------------------------------------------------------------
# Set dependency rule and include dependency lists
#------------------------------------------------------------------------------

.PHONY: dep
dep: $(DEPENDENCIES)

ifeq ($(findstring lnInclude,$(MAKECMDGOALS)),)
-include $(DEPENDENCIES)
endif


