SUFFIXES += .C

c++WARN     = -Wall -Wextra -Wold-style-cast -Wnon-virtual-dtor \
              -Wno-unused-parameter -Wno-invalid-offsetof -Wno-attributes

# Suppress some warnings for flex++
c++LESSWARN = -Wno-old-style-cast -Wno-unused-local-typedefs -Wno-array-bounds

# gnu++14 (not c++14): strict-ANSI mode hides POSIX math declarations
# (jn, yn, ...) in the MinGW-w64/UCRT headers
CC          = g++ -std=gnu++14 -m64

include $(DEFAULT_RULES)/c++$(WM_COMPILE_OPTION)

ptFLAGS     = -DNoRepository -ftemplate-depth-256

# -Wa,-mbig-obj: large template translation units exceed the default
# COFF section limit on x86_64
# No -fPIC: PE/COFF code is inherently position independent
c++FLAGS    = $(GFLAGS) $(c++WARN) $(c++OPT) $(c++DBUG) $(ptFLAGS) \
              $(LIB_HEADER_DIRS) -Wa,-mbig-obj

Ctoo        = $(WM_SCHEDULER) $(CC) $(c++FLAGS) -c $< -o $@
cxxtoo      = $(Ctoo)
cctoo       = $(Ctoo)
cpptoo      = $(Ctoo)

LINK_LIBS   = $(c++DBUG)

# PE linking: undefined symbols are always errors; ELF-only flags
# (--add-needed/--no-as-needed) do not apply
# --out-implib: emit an import library beside each DLL so dependents can
# link before the DLL's own dependencies are final (two-pass DLL cycles)
# --allow-multiple-definition: explicit template specialisations
# (e.g. processorFvPatchField<scalar>) coexist with implicit COMDAT
# instantiations from other translation units; ELF merges these as weak
# symbols but PE ld reports duplicates
LINKLIBSO   = $(CC) $(c++FLAGS) -shared -Wl,--enable-auto-import \
              -Wl,--allow-multiple-definition \
              -Wl,--out-implib,$(LIB).$(SO).a

LINKEXE     = $(CC) $(c++FLAGS) -Wl,--enable-auto-import \
              -Wl,--allow-multiple-definition

# flex++-generated sources include FlexLexer.h; MSYS2's flex installs it
# under /usr/include, which the native UCRT64 compiler must not search
# (Cygwin libc headers). A vendored copy (BSD-licensed, from flex 2.6.4)
# lives in these rules instead.
Ltoo = $E $(call QUIET_MESSAGE,flex++,$(<F)) \
    $(WM_SCHEDULER) flex -+ -o$(@D)/$(<F).C -f $< $(AND) \
    $(CC) $(c++FLAGS) $(c++LESSWARN) -I$(DEFAULT_RULES)/include \
    -c $(@D)/$(<F).C -o $@
