EXE_INC = \
    -I$(FOAM_MODULES)/fluidSolver/lnInclude \
    -I$(FOAM_MODULES)/isothermalFluid/lnInclude \
    -I$(LIB_SRC)/physicalProperties/lnInclude \
    -I$(LIB_SRC)/thermophysicalModels/basic/lnInclude \
    -I$(LIB_SRC)/MomentumTransportModels/momentumTransportModels/lnInclude \
    -I$(LIB_SRC)/MomentumTransportModels/compressible/lnInclude \
    -I$(LIB_SRC)/ThermophysicalTransportModels/thermophysicalTransportModel/lnInclude \
    -I$(LIB_SRC)/ThermophysicalTransportModels/fluid/lnInclude \
    -I$(LIB_SRC)/ThermophysicalTransportModels/fluidThermo/lnInclude \
    -I$(LIB_SRC)/finiteVolume/cfdTools \
    -I$(LIB_SRC)/finiteVolume/lnInclude \
    -I$(LIB_SRC)/meshTools/lnInclude \
    -I$(LIB_SRC)/sampling/lnInclude

LIB_LIBS = \
    -lfluidSolver \
    -lisothermalFluid \
    -lfluidThermophysicalModels \
    -lcompressibleMomentumTransportModels \
    -lcoupledThermophysicalTransportModels

ifeq ($(WM_ARCH),mingw_w64)
    # PE/COFF requires explicit link closure for directly referenced symbols
    # (ELF resolves them at load time), and for run-time-selected types whose
    # library is only reached transitively: libfluidThermophysicalTransportModel
    # provides thermal patch fields (externalCoupledTemperature, ...) that fluid
    # cases select at run time but which PE would otherwise drop.
    LIB_LIBS += -lfiniteVolume -lfluidThermophysicalTransportModel -lfluidThermoThermophysicalTransportModels -lfvConstraints -lfvModels
endif
