EXE_INC = \
    -I$(FOAM_MODULES)/fluidSolver/lnInclude \
    -I$(LIB_SRC)/MomentumTransportModels/momentumTransportModels/lnInclude \
    -I$(LIB_SRC)/MomentumTransportModels/incompressible/lnInclude \
    -I$(LIB_SRC)/physicalProperties/lnInclude \
    -I$(LIB_SRC)/finiteVolume/lnInclude \
    -I$(LIB_SRC)/meshTools/lnInclude

LIB_LIBS = \
    -lfluidSolver

ifeq ($(WM_ARCH),mingw_w64)
    # PE/COFF requires resolving directly-referenced symbols at link time
    # (fvMesh/fvSchemes/MRF/solver from finiteVolume, fvModels,
    # fvConstraints, incompressibleMomentumTransportModel::New,
    # viscosityModel::New); ELF gets them transitively at load time
    LIB_LIBS += \
        -lfiniteVolume \
        -lfvModels \
        -lfvConstraints \
        -lincompressibleMomentumTransportModels \
        -lphysicalProperties
endif
