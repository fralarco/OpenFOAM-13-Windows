EXE_INC = \
    -I$(FOAM_MODULES)/fluidSolver/lnInclude \
    -IphaseSystem/lnInclude \
    -IpopulationBalance/lnInclude \
    -I$(LIB_SRC)/meshTools/lnInclude \
    -I$(LIB_SRC)/finiteVolume/lnInclude \
    -I$(LIB_SRC)/sampling/lnInclude \
    -I$(LIB_SRC)/physicalProperties/lnInclude \
    -I$(LIB_SRC)/thermophysicalModels/basic/lnInclude \
    -I$(LIB_SRC)/twoPhaseModels/twoPhaseMixture/lnInclude \
    -I$(LIB_SRC)/twoPhaseModels/compressibleTwoPhases/lnInclude \
    -I$(LIB_SRC)/MomentumTransportModels/momentumTransportModels/lnInclude \
    -I$(LIB_SRC)/MomentumTransportModels/compressible/lnInclude \
    -I$(LIB_SRC)/MomentumTransportModels/phaseCompressible/lnInclude

LIB_LIBS = \
    -lfluidSolver \
    -lpopulationBalance

# Registration-only libraries: their contribution is the static-initialiser
# run-time-selection registration of patch fields / models / constraints (e.g.
# JohnsonJacksonParticleSlip, the kinetic-theory & thermophysical-transport &
# reaction models, fvModels, the limitPressure fvConstraint), not a directly
# referenced symbol.
_multiphaseEulerRegLibs = \
    -lmultiphaseEulerMomentumTransportModels \
    -lmultiphaseEulerThermophysicalTransportModels \
    -lmultiphaseEulerReactions \
    -lfvModels \
    -lfvConstraints

ifeq ($(WM_ARCH),mingw_w64)
    # PE/COFF drops an import DLL when no symbol is referenced directly, so the
    # registration-only libraries above never load and the solver reports
    # "Unknown ... type" (patch field JohnsonJacksonParticleSlip, constraint
    # limitPressure, ...). Force them into the import table with --whole-archive
    # so their registrations run when the module is loaded. They are real
    # libraries (no dummy variant), so there is no dummy/real symbol mismatch.
    # Also close the PE link for the directly referenced finiteVolume /
    # phaseSystem / fluidThermophysicalModels symbols (ELF resolves these at
    # load time).
    LIB_LIBS += -Wl,--whole-archive $(_multiphaseEulerRegLibs) -Wl,--no-whole-archive \
        -lfiniteVolume -lphaseSystem -lfluidThermophysicalModels
else
    LIB_LIBS += $(_multiphaseEulerRegLibs)
endif
