EXE_INC = \
    -IfoamToVTK/lnInclude \
    -I$(LIB_SRC)/tracking/lnInclude \
    -I$(LIB_SRC)/lagrangian/basic/lnInclude \
    -I$(LIB_SRC)/finiteVolume/lnInclude \
    -I$(LIB_SRC)/polyTopoChange/lnInclude \
    -I$(LIB_SRC)/meshTools/lnInclude \
    -I$(LIB_SRC)/fileFormats/lnInclude

EXE_LIBS = \
    -lfoamToVTK \
    -lpolyTopoChange \
    -llagrangian \
    -lgenericFvFields \
    -lfileFormats

ifeq ($(WM_ARCH),mingw_w64)
    # PE/COFF requires explicit link closure for directly
    # referenced symbols; ELF resolves them at load time
    EXE_LIBS += -lfiniteVolume
endif

ifeq ($(WM_ARCH),mingw_w64)
    # PE/COFF requires explicit link closure for directly
    # referenced symbols; ELF resolves them at load time
    EXE_LIBS += -lmeshTools
endif
