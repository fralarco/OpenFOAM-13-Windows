EXE_INC = \
    -I$(LIB_SRC)/parallel/decompose/decompositionMethods/lnInclude \
    -I$(LIB_SRC)/mesh/snappyHexMesh/lnInclude \
    -I$(LIB_SRC)/meshTools/lnInclude \
    -I$(LIB_SRC)/meshCheck/lnInclude \
    -I$(LIB_SRC)/fileFormats/lnInclude \
    -I$(LIB_SRC)/triSurface/lnInclude \
    -I$(LIB_SRC)/surfMesh/lnInclude \
    -I$(LIB_SRC)/polyTopoChange/lnInclude \
    -I$(LIB_SRC)/finiteVolume/lnInclude

EXE_LIBS = \
    -lfiniteVolume \
    -lgenericFvFields \
    -ldecompositionMethods \
    -L$(FOAM_LIBBIN)/dummy -lscotchDecomp -lptscotchDecomp \
    -lmeshTools \
    -lmeshCheck \
    -lsurfMesh \
    -lfileFormats \
    -lpolyTopoChange \
    -lsnappyHexMesh

ifeq ($(WM_ARCH),mingw_w64)
    # PE/COFF requires explicit link closure: triSurface field typeNames
    # (DimensionedField<..., triSurfacePointGeoMesh>) live in libtriSurface
    EXE_LIBS += -ltriSurface
endif
